{
  "permissions": {
    "allow": [
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(swift build:*)",
      "Bash(swift test:*)",
      "Bash(swift run:*)",
      "Bash(/bin/zsh -l -c \"nonexistent-command --output-format=text --print Hello\")",
      "Bash(echo:*)",
      "Bash(timeout 10 swift run:*)",
